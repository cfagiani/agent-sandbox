# Directory containing your GGUF model files
MODEL_DIR="/path/to/your/models"

# Path to the llama-server binary
LLAMA_SERVER="/path/to/llama-server"

# PORT for llama.cpp server
PORT=11434

# Name for the docker image
IMAGE_NAME="claude-code-dev"

# LLM Context Size (set based on model)
CONTEXT_SIZE=262144

# Model alias used to select LLM_OPTIONS in start-llama.sh
# Currently supported: qwen3.6 (uses draft-mtp speculation)
# Any other value falls back to generic options (no speculation)
MODEL_ALIAS="local"

# LLM_OPTIONS are selected in start-llama.sh based on MODEL_ALIAS